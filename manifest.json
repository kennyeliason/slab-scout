{
  "manifest_version": 3,
  "name": "Slab Scout",
  "version": "1.0.0",
  "description": "See graded card comps instantly while browsing raw cards on eBay. Know the grading gap before you buy.",
  "author": "Kenny Eliason",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.ebay.com/*", "https://api.ebay.com/*", "https://api.openai.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.ebay.com/itm/*", "https://www.ebay.com/p/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
